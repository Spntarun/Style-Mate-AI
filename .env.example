# ─────────────────────────────────────────────────────────────
#  StyleMate — Environment Variables Template
#  Copy this file to .env and fill in your values
#  The app works with all defaults — no changes needed.
# ─────────────────────────────────────────────────────────────

# Flask secret key — change this in production!
SECRET_KEY=stylemate_secret_key_change_in_production

# FASHN VTON 1.5 weights directory
# Default: ./fashn-weights (relative to project root)
# Change this if you want to store weights somewhere else (e.g., another drive)
# FASHN_WEIGHTS_DIR=D:\fashn-weights
